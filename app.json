{
  "expo": {
    "name": "GreenLedger",
    "slug": "greenledger",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./app/assets/greenledger-logo.png",
    "scheme": "greenledger",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jui.greenledger"
    },
    "android": {
      "package": "com.jui.greenledger",
      "adaptiveIcon": {
        "foregroundImage": "./app/assets/greenledger-logo.png",
        "backgroundColor": "#E9E0D0"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./app/assets/greenledger-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./app/assets/greenledger-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#E9E0D0"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e38cff6f-b31b-4614-a399-0d0b1ba4e8d8"
      }
    }
  }
}
